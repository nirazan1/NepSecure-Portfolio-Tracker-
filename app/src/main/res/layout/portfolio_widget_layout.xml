<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_background">

    <!-- Header Row: Title + Refresh Button -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_toLeftOf="@+id/widget_refresh_button"
            android:layout_alignParentLeft="true">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NepSecure Portfolio Tracker"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_last_sync"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sync: Never"
                android:textColor="#94A3B8"
                android:textSize="9sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/widget_refresh_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:padding="4dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_rotate"
            android:contentDescription="Refresh Data" />
    </RelativeLayout>

    <!-- NEPSE Status + DateTime Row -->
    <LinearLayout
        android:id="@+id/widget_nepse_info_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_nepse_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#10B981"
            android:textSize="9sp"
            android:textStyle="bold"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:paddingTop="1dp"
            android:paddingBottom="1dp"
            android:background="#1A10B981" />

        <TextView
            android:id="@+id/widget_nepse_datetime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6dp"
            android:text=""
            android:textColor="#94A3B8"
            android:textSize="9sp" />
    </LinearLayout>

    <!-- Divider -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:background="#232B3E" />

    <!-- Today's Return -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="10"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="6"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today's Return"
                android:textColor="#94A3B8"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_today_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rs 0.00"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="4"
            android:orientation="vertical"
            android:gravity="right">

            <TextView
                android:id="@+id/widget_today_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00%"
                android:textColor="#10B981"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="4dp"
        android:background="#232B3E" />

    <!-- Indices Section -->
    <LinearLayout
        android:id="@+id/widget_indices_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- NEPSE Index Row -->
        <LinearLayout
            android:id="@+id/widget_nepse_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="3dp"
            android:weightSum="3">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.1"
                android:textColor="#94A3B8"
                android:textStyle="bold"
                android:textSize="9sp"
                android:text="NEPSE" />

            <TextView
                android:id="@+id/widget_nepse_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.1"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="9sp"
                android:text="—" />

            <TextView
                android:id="@+id/widget_nepse_change"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:gravity="right"
                android:textColor="#10B981"
                android:textStyle="bold"
                android:textSize="9sp"
                android:text="—" />
        </LinearLayout>

        <!-- Sensitive Index Row -->
        <LinearLayout
            android:id="@+id/widget_sensitive_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="3dp"
            android:weightSum="3">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.1"
                android:textColor="#94A3B8"
                android:textStyle="bold"
                android:textSize="9sp"
                android:text="SENSITIVE" />

            <TextView
                android:id="@+id/widget_sensitive_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.1"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="9sp"
                android:text="—" />

            <TextView
                android:id="@+id/widget_sensitive_change"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:gravity="right"
                android:textColor="#10B981"
                android:textStyle="bold"
                android:textSize="9sp"
                android:text="—" />
        </LinearLayout>

        <!-- Banking Index Row -->
        <LinearLayout
            android:id="@+id/widget_banking_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="3dp"
            android:weightSum="3">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.1"
                android:textColor="#94A3B8"
                android:textStyle="bold"
                android:textSize="9sp"
                android:text="BANKING" />

            <TextView
                android:id="@+id/widget_banking_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.1"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="9sp"
                android:text="—" />

            <TextView
                android:id="@+id/widget_banking_change"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:gravity="right"
                android:textColor="#10B981"
                android:textStyle="bold"
                android:textSize="9sp"
                android:text="—" />
        </LinearLayout>
    </LinearLayout>

    <!-- News Divider -->
    <FrameLayout
        android:id="@+id/widget_news_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="4dp"
        android:background="#232B3E" />

    <!-- News Section -->
    <LinearLayout
        android:id="@+id/widget_news_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LATEST NEWS"
            android:textColor="#94A3B8"
            android:textSize="8sp"
            android:textStyle="bold"
            android:layout_marginBottom="3dp" />

        <TextView
            android:id="@+id/widget_news_item_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:layout_marginTop="1dp" />

        <TextView
            android:id="@+id/widget_news_item_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:layout_marginTop="1dp" />

        <TextView
            android:id="@+id/widget_news_item_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:layout_marginTop="1dp" />

        <TextView
            android:id="@+id/widget_news_item_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:layout_marginTop="1dp" />

        <TextView
            android:id="@+id/widget_news_item_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:layout_marginTop="1dp" />

        <TextView
            android:id="@+id/widget_news_item_6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:layout_marginTop="1dp" />

        <TextView
            android:id="@+id/widget_news_item_7"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:layout_marginTop="1dp" />

        <TextView
            android:id="@+id/widget_news_item_8"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:layout_marginTop="1dp" />

        <TextView
            android:id="@+id/widget_news_item_9"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:layout_marginTop="1dp" />

        <TextView
            android:id="@+id/widget_news_item_10"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:layout_marginTop="1dp" />
    </LinearLayout>

</LinearLayout>
