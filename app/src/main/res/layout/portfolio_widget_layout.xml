<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stock Portfolio"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_last_sync"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/widget_title"
            android:text="Sync: Never"
            android:textColor="#94A3B8"
            android:textSize="10sp" />

        <ImageView
            android:id="@+id/widget_refresh_button"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:padding="4dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_rotate"
            android:contentDescription="Refresh Data" />
    </RelativeLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#232B3E" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="10"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="6"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today's Return"
                android:textColor="#94A3B8"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_today_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rs 0.00"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="4"
            android:orientation="vertical"
            android:gravity="right">

            <TextView
                android:id="@+id/widget_today_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00%"
                android:textColor="#10B981"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_holdings_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical">

        <!-- Top Gainer Row -->
        <LinearLayout
            android:id="@+id/widget_gainer_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:weightSum="3">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:textColor="#10B981"
                android:textStyle="bold"
                android:textSize="11sp"
                android:text="GAINER" />
            <TextView
                android:id="@+id/widget_gainer_ticker"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="11sp"
                android:text="AAPL" />
            <TextView
                android:id="@+id/widget_gainer_price"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.7"
                android:gravity="center"
                android:textColor="#E2E8F0"
                android:textSize="11sp"
                android:text="$185.50" />
            <TextView
                android:id="@+id/widget_gainer_change"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.7"
                android:gravity="right"
                android:textColor="#10B981"
                android:textStyle="bold"
                android:textSize="11sp"
                android:text="+2.35%" />
        </LinearLayout>

        <!-- Top Loser Row -->
        <LinearLayout
            android:id="@+id/widget_loser_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:weightSum="3">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:textColor="#EF4444"
                android:textStyle="bold"
                android:textSize="11sp"
                android:text="LOSER" />
            <TextView
                android:id="@+id/widget_loser_ticker"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="11sp"
                android:text="GOOGL" />
            <TextView
                android:id="@+id/widget_loser_price"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.7"
                android:gravity="center"
                android:textColor="#E2E8F0"
                android:textSize="11sp"
                android:text="$130.40" />
            <TextView
                android:id="@+id/widget_loser_change"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.7"
                android:gravity="right"
                android:textColor="#EF4444"
                android:textStyle="bold"
                android:textSize="11sp"
                android:text="-0.61%" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
